  "entryPoints": [
    "packages/core/src/index.ts"
  ],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "entryPointStrategy": "resolve",
  "tsconfig": "packages/core/tsconfig.json",
